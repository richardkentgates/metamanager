#!/usr/bin/env bash
set -euo pipefail

readonly USAGE="Usage: promote (stage [title]) | (release --version X.Y.Z)"

stage() {
  local title="${1:-chore: promote dev → test}"
  echo "==> Promoting dev → test"

  local branch="promote/dev-to-test"

  git fetch origin dev test
  if git diff --exit-code origin/dev origin/test >/dev/null 2>&1; then
    echo "!! dev and test have identical trees — already promoted."
    exit 1
  fi

  # Build a conflict-free merge branch off test, auto-resolving in favour of dev
  git branch -D "$branch" 2>/dev/null || true
  git checkout -b "$branch" origin/test
  if ! git merge origin/dev --no-edit -X theirs 2>/dev/null; then
    # If -X theirs didn't fully resolve, take dev's version of any remaining conflict
    git checkout --theirs -- . 2>/dev/null || true
    git add -A
    git commit --no-edit 2>/dev/null || true
  fi
  git push origin "$branch" --force

  gh pr create --base test --head "$branch" \
    --title "$title" \
    --body "Automated promotion of dev → test."
  echo "==> PR created at https://github.com/richardkentgates/metamanager/pull/$(gh pr view --json number --jq .number 2>/dev/null || echo '?')"
  echo "   CI will run on test. Merge with: gh pr merge --squash"
}

release() {
  local version=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --version) version="$2"; shift 2 ;;
      *) echo "!! Unknown option: $1"; echo "$USAGE"; exit 1 ;;
    esac
  done
  if [ -z "$version" ]; then
    echo "!! --version is required for release (e.g. --version 2.2.0)"
    exit 1
  fi
  if ! echo "$version" | grep -qxP '^\d+\.\d+\.\d+$'; then
    echo "!! Version must be semver (e.g. 2.2.0), got: $version"
    exit 1
  fi

  echo "==> Promoting test → main (v$version)"

  local branch="release/v$version"

  git fetch origin test main
  if git diff --exit-code origin/test origin/main >/dev/null 2>&1; then
    echo "!! test and main have identical trees — already promoted."
    exit 1
  fi

  git branch -D "$branch" 2>/dev/null || true
  git checkout -b "$branch" origin/main
  if ! git merge origin/test --no-edit -X theirs 2>/dev/null; then
    git checkout --theirs -- . 2>/dev/null || true
    git add -A
    git commit --no-edit 2>/dev/null || true
  fi
  git push origin "$branch" --force

  gh pr create --base main --head "$branch" \
    --title "release: v$version" \
    --body "Automated release v$version — promoting test → main.

## Pre-merge checklist
- [ ] CI green on this PR
- [ ] Version bumped to $version in metamanager.php (MM_VERSION)
- [ ] CHANGELOG.md updated
- [ ] Tag after merge: \`git tag v$version && git push origin v$version\`"
  echo "==> PR created."
  echo "   After merge, tag with: git tag v$version && git push origin v$version"
}

cleanup() {
  local branch
  branch=$(git symbolic-ref --short HEAD 2>/dev/null || true)
  if [[ "$branch" == promote/* ]] || [[ "$branch" == release/* ]]; then
    git checkout dev 2>/dev/null || git checkout test 2>/dev/null || true
  fi
}

main() {
  if [ $# -eq 0 ]; then
    echo "$USAGE"
    exit 1
  fi

  local cmd="$1"
  shift

  case "$cmd" in
    stage)
      stage "$@"
      cleanup
      ;;
    release)
      release "$@"
      cleanup
      ;;
    *)
      echo "Unknown command: $cmd"
      echo "$USAGE"
      exit 1
      ;;
  esac
}

main "$@"
