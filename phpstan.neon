parameters:
    level: 5
    paths:
        - metamanager.php
        - uninstall.php
        - includes/
    excludePaths:
        analyseAndScan:
            # Exclude files that extend WordPress classes (non-ignorable errors)
            - includes/class-mm-cli.php
            - includes/class-mm-admin.php
            - includes/metadata/modules/class-mm-mod-business-contact.php
            # Exclude files with WordPress class type hints
            - includes/metadata/class-mm-page-context.php
            - includes/class-mm-job-queue.php
            - includes/class-mm-upload-notify.php
            - tests/
    treatPhpDocTypesAsCertain: false
    reportUnmatchedIgnoredErrors: false
    ignoreErrors:
        # WordPress functions/classes not available without stubs
        - '#not found#'
        - '#unknown class#'
        - '#invalid type#'
        - '#invalid return type#'
        # isset() checks that PHPStan thinks are always true
        - '#isset\(\) always exists#'
        # array_map callback type issues
        - '#Parameter .*callback of function array_map expects#'
