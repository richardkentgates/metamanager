{
    "name": "richardkentgates/metamanager",
    "description": "WordPress plugin for lossless media compression and metadata management",
    "type": "wordpress-plugin",
    "license": "GPL-3.0-or-later",
    "require": {
        "php": ">=8.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.0",
        "szepeviktor/phpstan-wordpress": "^0.7 || ^1.0",
        "php-stubs/wordpress-stubs": "^6.0",
        "php-stubs/wp-cli-stubs": "^2.12",
        "phpunit/phpunit": "^10.5 || ^11.0",
        "wp-phpunit/wp-phpunit": "^6.5"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "autoload": {
        "classmap": ["includes/"]
    }
}
