{
  "name": "richardkentgates/metamanager",
  "description": "Metadata management and compression plugin for WordPress",
  "type": "wordpress-plugin",
  "require": {
    "php": ">=8.0"
  },
  "require-dev": {
    "phpstan/phpstan": "^1.10",
    "phpstan/extension-installer": "^1.3",
    "szepeviktor/phpstan-wordpress": "^1.1",
    "php-stubs/wordpress-stubs": "^6.2",
    "php-stubs/wp-cli-stubs": "^2.8"
  },
  "config": {
    "allow-plugins": {
      "phpstan/extension-installer": true
    }
  },
  "scripts": {
    "analyse": "phpstan analyse --configuration phpstan.neon",
    "phpunit": "phpunit --configuration tests/phpunit.xml"
  }
}
