#!/usr/bin/make -f
# MetaManager — thin Debian package.
# No build step (PHP/bash); dh_install stages files per debian/metamanager.install.

%:
	dh $@

# No compilation, no build artifacts.
override_dh_auto_build:

# Tests require a live WordPress + MySQL stack; run them in CI, not at package build.
override_dh_auto_test:

# Exclude dev-only artifacts that live in the source tree from the staged install.
override_dh_install:
	dh_install --exclude=tests --exclude=.github --exclude=vendor --exclude=docs --exclude=stubs --exclude=wiki --exclude=*.map --exclude=phpstan.neon --exclude=phpunit.xml

# We stage to /usr/local/lib/metamanager (not /usr/local/bin), so dh_usrlocal
# has nothing to do and errors on the file layout. Skip it.
override_dh_usrlocal:
